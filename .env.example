# --- Google Cloud Configuration ---
# Your GCP Project ID (found in the Google Cloud Console)
GCP_PROJECT_ID=your-project-id-here

# The deployment region for Vertex AI services
GCP_LOCATION=us-central1

# Path to your Google Service Account JSON key (for local development)
GOOGLE_APPLICATION_CREDENTIALS=gcp-key.json

# --- Qdrant Vector Database ---
# The cluster URL from your Qdrant Cloud dashboard
QDRANT_URL=https://your-cluster-id.us-east-4.aws.cloud.qdrant.io:6333

# Your Qdrant API Key (Read/Write access required for ingestion)
QDRANT_API_KEY=your-api-key-here

# --- Application Settings ---
# Optional: Set to 'DEBUG' for more verbose logging during setup
LOG_LEVEL=INFO